  streamUrl String?
  updatedAt DateTime @updatedAt
}
*/


model RadioStatus {
  id            String   @id
  live          Boolean  @default(false)
  title         String?  @default("Rádio Offline")
  subtitle      String?  @default("")
  streamUrl     String?
  status        String   @default("OFFLINE")
  nextProgramAt String?  @default("")
  allowPlay     Boolean  @default(false)
  badgeLabel    String?  @default("Offline")
  updatedAt     DateTime @updatedAt
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

enum Role {
  ADMIN
  USER
  PASTOR
  SUPERADMIN
}

enum Plano {
  FREE
  PRO
  PREMIUM
}
