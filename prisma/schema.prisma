generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  role          Role        @default(USER)
  igrejaId      String?
  senha         String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cargoId       String?
  accounts      Account[]
  igrejasAdmin  Igreja?     @relation("IgrejaAdmin")
  permissoes    Permissao[]
  sessions      Session[]
  cargo         Cargo?      @relation(fields: [cargoId], references: [id])
  igreja        Igreja?     @relation(fields: [igrejaId], references: [id])

  @@map("users")
}

model Igreja {
  id                  String                 @id @default(cuid())
  nome                String
  slug                String                 @unique
  plano               Plano                  @default(FREE)
  adminId             String?                @unique
  membros             Int                    @default(1)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  cargos              Cargo[]
  eventos             Evento[]
  admin               User?                  @relation("IgrejaAdmin", fields: [adminId], references: [id])
  publico             IgrejaPublico?
  cronogramaAnual     CronogramaAnual[]
  membrosLista        Membro[]
  users               User[]
  ebdTurmas           EscolaDominicalTurma[]
  departamentos       Departamento[]
  backupConfig        BackupConfig?
  historia HistoriaIgreja?
  backupGlobalTargets BackupGlobalConfig[]   @relation("BackupGlobalTargetIgreja")

  @@map("igrejas")
}

model Cargo {
  id        String   @id @default(cuid())
  nome      String
  igrejaId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  igreja    Igreja   @relation(fields: [igrejaId], references: [id])
  users     User[]

  @@unique([igrejaId, nome])
  @@map("cargos")
}

model Permissao {
  id           String   @id @default(cuid())
  userId       String
  recurso      String
  ler          Boolean  @default(false)
  criar        Boolean  @default(false)
  editar       Boolean  @default(false)
  deletar      Boolean  @default(false)
  compartilhar Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recurso])
  @@map("permissoes")
}

model Membro {
  id                     String    @id @default(cuid())
  igrejaId               String
  numeroSequencial       Int
  nome                   String
  telefone               String?
  endereco               String?
  numeroEndereco         String?
  bairro                 String?
  cidade                 String?
  estado                 String?
  estadoCivil            String?
  nomeMae                String?
  nomePai                String?
  rg                     String?
  cpf                    String?   @db.VarChar(11)
  cargo                  String
  dataNascimento         DateTime?
  dataBatismo            DateTime?
  numeroCarteirinha      String?
  dataCriacaoCarteirinha DateTime?
  dataVencCarteirinha    DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  observacoes            String?

  ativo Boolean @default(true)

  igreja Igreja @relation(fields: [igrejaId], references: [id], onDelete: Cascade)

  departamentosResponsavel DepartamentoResponsavel[]

  ebdTurmasComoProfessor EscolaDominicalTurma[]      @relation("ProfessorEbd")
  ebdTurmasAluno         EscolaDominicalTurmaAluno[]
  ebdFrequencias         EscolaDominicalFrequencia[]

  @@unique([igrejaId, numeroSequencial])
  @@index([igrejaId])
  @@index([igrejaId, nome])
  @@index([igrejaId, cargo])
  @@index([igrejaId, dataVencCarteirinha])
  @@map("membros")
}

model Evento {
  id     String @id @default(cuid())
  titulo String

  data DateTime @db.Timestamp(0)

  igrejaId  String
  criadoPor String

  imagemUrl      String?
  imagemPublicId String?
  
  imagens EventoImagem[]

  descricao   String?
  local       String?
  responsavel String?
  tipo        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  igreja Igreja @relation(fields: [igrejaId], references: [id])

  @@map("eventos")
}

model EventoImagem {
  id        String   @id @default(cuid())
  eventoId  String
  imageUrl  String
  publicId  String
  titulo    String?
  altText   String?
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evento Evento @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@index([eventoId, ordem])
  @@map("evento_imagens")
}

model IgrejaPublico {
  id                          String           @id @default(cuid())
  igrejaId                    String           @unique
  bannerSubtitle              String?
  heroSlogan                  String?
  boasVindasTexto             String?
  pastorNome                  String?
  pastorCargo                 String?
  pastorSubtitle              String?
  pastorMensagem              String?
  pastorImageUrl              String?
  pastorImagePublicId         String?
  heroBackgroundImageUrl      String?
  heroBackgroundImagePublicId String?
  whatsappUrl                 String?
  telefonePublico             String?
  emailPublico                String?
  footerDescricao             String?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  facebookUrl                 String?
  instagramUrl                String?
  endereco                    String?
  cronograma                  CronogramaItem[]
  horarios                    HorarioPublico[]
  igreja                      Igreja           @relation(fields: [igrejaId], references: [id], onDelete: Cascade)

  @@map("igrejas_publico")
}

model HorarioPublico {
  id              String        @id @default(cuid())
  igrejaPublicoId String

  texto           String
  diaLabel        String?
  hora            String?
  tituloCard      String?
  descricaoCard   String?

  ordem           Int           @default(0)
  igrejaPublico   IgrejaPublico @relation(fields: [igrejaPublicoId], references: [id], onDelete: Cascade)

  @@index([igrejaPublicoId])
  @@map("horarios_publico")
}

model CronogramaItem {
  id              String        @id @default(cuid())
  igrejaPublicoId String
  dia             DiaSemana
  hora            String
  titulo          String
  ordem           Int           @default(0)
  igrejaPublico   IgrejaPublico @relation(fields: [igrejaPublicoId], references: [id], onDelete: Cascade)

  @@index([igrejaPublicoId])
  @@index([dia])
  @@map("cronograma_itens")
}

model CronogramaAnual {
  id        String   @id @default(cuid())
  igrejaId  String
  titulo    String
  data      DateTime
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  igreja Igreja @relation(fields: [igrejaId], references: [id], onDelete: Cascade)

  @@index([igrejaId])
  @@map("cronograma_anual")
}

//BACKUP
model BackupConfig {
  id             String    @id @default(cuid())
  igrejaId       String    @unique
  ativo          Boolean   @default(false)
  intervalo      String    @default("diario")
  hora           String    @default("02:00")
  ultimoBackupEm DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  igreja Igreja @relation(fields: [igrejaId], references: [id], onDelete: Cascade)

  @@index([ativo])
  @@map("backup_configs")
}

model BackupGlobalConfig {
  id             String    @id
  ativo          Boolean   @default(false)
  intervalo      String    @default("diario")
  hora           String    @default("02:00")
  modo           String    @default("todas")
  igrejaId       String?
  ultimoBackupEm DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  igreja Igreja? @relation("BackupGlobalTargetIgreja", fields: [igrejaId], references: [id], onDelete: SetNull)

  @@index([ativo])
  @@map("backup_global_configs")
}

model RadioStatus {
  id            String   @id
  live          Boolean  @default(false)
  title         String?  @default("Rádio Offline")
  subtitle      String?  @default("")
  streamUrl     String?
  status        String   @default("OFFLINE")
  nextProgramAt String?  @default("")
  allowPlay     Boolean  @default(false)
  badgeLabel    String?  @default("Offline")
  updatedAt     DateTime @updatedAt
}

model RadioStatsHistory {
  id        String   @id @default(cuid())
  current   Int      @default(0)
  peak      Int      @default(0)
  max       Int      @default(0)
  online    Boolean  @default(false)
  uptime    Int?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("radio_stats_history")
}

model RadioProgramacao {
  id           String    @id @default(cuid())
  diaSemana    DiaSemana
  horaInicio   String
  horaFim      String
  titulo       String
  subtitulo    String?
  responsavel  String?
  ativo        Boolean   @default(true)
  ordem        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([diaSemana, ordem])
  @@map("radio_programacao")
}

model EscolaDominicalTurma {
  id           String   @id @default(cuid())
  igrejaId     String
  nome         String
  departamento String?
  professorId  String
  ativa        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  igreja    Igreja                          @relation(fields: [igrejaId], references: [id], onDelete: Cascade)
  professor Membro                          @relation("ProfessorEbd", fields: [professorId], references: [id])
  alunos    EscolaDominicalTurmaAluno[]
  registros EscolaDominicalRegistroMensal[]

  @@unique([igrejaId, nome])
  @@index([igrejaId])
  @@index([professorId])
  @@map("ebd_turmas")
}

model EscolaDominicalTurmaAluno {
  id        String   @id @default(cuid())
  turmaId   String
  membroId  String
  createdAt DateTime @default(now())

  turma  EscolaDominicalTurma @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  membro Membro               @relation(fields: [membroId], references: [id], onDelete: Cascade)

  @@unique([turmaId, membroId])
  @@index([membroId])
  @@map("ebd_turma_alunos")
}

model EscolaDominicalRegistroMensal {
  id          String   @id @default(cuid())
  turmaId     String
  mes         Int
  ano         Int
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  turma       EscolaDominicalTurma        @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  frequencias EscolaDominicalFrequencia[]
  domingos    EscolaDominicalDomingo[]

  @@unique([turmaId, mes, ano])
  @@index([mes, ano])
  @@map("ebd_registros_mensais")
}

model EscolaDominicalDomingo {
  id               String   @id @default(cuid())
  registroMensalId String
  domingoNumero    Int
  visitantes       Int      @default(0)
  oferta           Decimal? @db.Decimal(10, 2)
  revistasLivros   Int      @default(0)
  observacao       String?
  isFolgaGeral     Boolean @default(false)
  motivoFolga      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  registroMensal EscolaDominicalRegistroMensal @relation(fields: [registroMensalId], references: [id], onDelete: Cascade)

  @@unique([registroMensalId, domingoNumero])
  @@map("ebd_domingos")
}

model EscolaDominicalFrequencia {
  id               String    @id @default(cuid())
  registroMensalId String
  membroId         String
  domingoNumero    Int
  status           EbdStatus @default(FALTA)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  registroMensal EscolaDominicalRegistroMensal @relation(fields: [registroMensalId], references: [id], onDelete: Cascade)
  membro         Membro                        @relation(fields: [membroId], references: [id], onDelete: Cascade)

  @@unique([registroMensalId, membroId, domingoNumero])
  @@index([membroId])
  @@index([domingoNumero])
  @@map("ebd_frequencias")
}

model SiteCounter {
  key       String   @id
  total     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model SiteAccess {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  path         String?
  referrer     String?
  userAgent    String?
  deviceType   String?
  visitorId    String?
  ipAddress    String?
  ipHash       String?
  ipCountry    String?
  ipRegion     String?
  ipCity       String?

  displayMode  String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?

  @@index([createdAt])
  @@index([deviceType])
  @@index([path])
  @@index([visitorId])
  @@index([ipAddress])
  @@index([ipHash])
  @@index([ipCountry])
  @@index([ipRegion])
  @@index([ipCity])
  @@index([displayMode])
  @@index([utmSource])
  @@index([utmMedium])
  @@index([utmCampaign])
}

model Departamento {
  id                   String   @id @default(cuid())
  igrejaId             String
  nome                 String
  slug                 String
  descricao            String?
  capaUrl              String?
  capaPublicId         String?
  diasFuncionamento    String?
  horarioFuncionamento String?
  ordem                Int      @default(0)
  ativo                Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  igreja       Igreja                   @relation(fields: [igrejaId], references: [id], onDelete: Cascade)
  responsaveis DepartamentoResponsavel[]
  albuns       DepartamentoAlbum[]

  @@unique([igrejaId, slug])
  @@index([igrejaId, ativo])
  @@map("departamentos")
}

model DepartamentoAlbum {
  id                 String   @id @default(cuid())
  departamentoId     String
  titulo             String
  descricao          String?
  dataEvento         DateTime?
  capaUrl            String?
  capaPublicId       String?
  ordem              Int      @default(0)
  ativo              Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  departamento Departamento            @relation(fields: [departamentoId], references: [id], onDelete: Cascade)
  imagens      DepartamentoAlbumImagem[]

  @@index([departamentoId, ativo])
  @@index([departamentoId, ordem])
  @@map("departamento_albuns")
}

model DepartamentoAlbumImagem {
  id          String   @id @default(cuid())
  albumId     String
  titulo      String?
  altText     String?
  imageUrl    String
  publicId    String
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  album DepartamentoAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId, ordem])
  @@map("departamento_album_imagens")
}
model DepartamentoResponsavel {
  id             String   @id @default(cuid())
  departamentoId String
  membroId       String
  cargoTitulo    String
  bio            String?
  fotoUrl        String?
  fotoPublicId   String?
  ordem          Int      @default(0)
  ativo          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  departamento Departamento @relation(fields: [departamentoId], references: [id], onDelete: Cascade)
  membro       Membro       @relation(fields: [membroId], references: [id], onDelete: Restrict)

  @@unique([departamentoId, membroId])
  @@index([membroId])
  @@map("departamento_responsaveis")
}

model HistoriaIgreja {
  id                  String               @id @default(cuid())
  igrejaId            String               @unique
  titulo              String
  subtitulo           String?
  texto               String?
  imagemCapaUrl       String?
  imagemCapaPublicId  String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  igreja Igreja @relation(fields: [igrejaId], references: [id], onDelete: Cascade)
  marcos HistoriaIgrejaMarco[]

  @@map("historias_igreja")
}

model HistoriaIgrejaMarco {
  id               String         @id @default(cuid())
  historiaIgrejaId String
  ano              String
  titulo           String
  descricao        String?
  ordem            Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  historia HistoriaIgreja @relation(fields: [historiaIgrejaId], references: [id], onDelete: Cascade)

  @@index([historiaIgrejaId])
  @@map("historias_igreja_marcos")
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

enum Role {
  ADMIN
  USER
  PASTOR
  SUPERADMIN
}

enum Plano {
  FREE
  PRO
  PREMIUM
}

enum EbdStatus {
  PRESENTE
  FALTA
}
